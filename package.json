{
  "name": "command-center",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Full-stack command center app runnable on localhost:3005.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run typecheck && npm --workspaces --if-present run build",
    "build:app": "npm --workspace @workspace/app run build",
    "build:api": "npm --workspace @workspace/api-server run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "tsc --build && npm --workspaces --if-present run typecheck",
    "test": "npm --workspace @workspace/tests run test"
  },
  "private": true,
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "scripts",
    "tests"
  ],
  "dependencies": {
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@vitejs/plugin-react": "^5.0.4",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.3",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "vite": "^7.3.2"
  }
}
